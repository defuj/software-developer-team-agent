      "mode": "subagent",
      "prompt": "{file:.opencode/agents/seo-specialist.md}",
      "model": "anthropic/claude-sonnet-4-20250514",
      "temperature": 0.4,
      "color": "#84cc16",
      "permission": {
        "edit": "allow",
        "bash": {
