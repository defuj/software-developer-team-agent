          "yarn *": "allow",
          "git status": "allow",
          "git diff": "allow",
          "git log*": "allow",
          "npx playwright*": "allow"
        },
        "webfetch": "allow",
        "skill": {
          "*": "allow"
        },
        "mcp": {
          "playwright": "allow"
